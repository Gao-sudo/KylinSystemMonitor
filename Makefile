dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents /usr/lib/x86_64-linux-gnu/qt5/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents controller/processcontroller.h controller/systemcontroller.h controller/filesystemcontroller.h controller/exportcontroller.h model/processmodel.h model/systemmodel.h model/sensorsreader.h model/sensormodel.h service/asyncmonitor.h service/cryptohelper.h view/systemoverviewwidget.h view/resourcemonitorwidget.h view/processmanagerwidget.h view/filesystemmonitor.h view/dataexportwidget.h view/processreportdialog.h mainwindow.h $(DISTDIR)/
	$(COPY_FILE) --parents controller/processcontroller.cpp controller/systemcontroller.cpp controller/filesystemcontroller.cpp controller/exportcontroller.cpp model/processmodel.cpp model/systemmodel.cpp model/sensorsreader.cpp model/sensormodel.cpp service/asyncmonitor.cpp service/cryptohelper.cpp view/systemoverviewwidget.cpp view/resourcemonitorwidget.cpp view/processmanagerwidget.cpp view/filesystemmonitor.cpp view/dataexportwidget.cpp view/processreportdialog.cpp main.cpp mainwindow.cpp $(DISTDIR)/
	$(COPY_FILE) --parents /home/china/桌面/KylinSystemMonitor/KylinSystemMonitor_zh_CN.ts $(DISTDIR)/


